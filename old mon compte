    function closeMobileNav(mobileNav, burgerBtn) {
      if (!mobileNav || !burgerBtn) return;
      mobileNav.classList.remove("open");
      burgerBtn.setAttribute("aria-expanded", "false");
    }

    function openMobileNav(mobileNav, burgerBtn) {
      if (!mobileNav || !burgerBtn) return;
      mobileNav.classList.add("open");
      burgerBtn.setAttribute("aria-expanded", "true");
    }

    function initMobileMenu() {
      const burgerBtn = document.getElementById("burger-button");
      const mobileNav = document.getElementById("mobile-nav");

      if (!burgerBtn || !mobileNav) {
        return;
      }

      burgerBtn.addEventListener("click", () => {
        const isOpen = mobileNav.classList.contains("open");
        if (isOpen) {
          closeMobileNav(mobileNav, burgerBtn);
        } else {
          openMobileNav(mobileNav, burgerBtn);
        }
      });

      mobileNav.addEventListener("click", (e) => {
        const target = e.target;
        if (target instanceof HTMLElement && target.tagName === "A") {
          closeMobileNav(mobileNav, burgerBtn);
        }
      });

      document.addEventListener("click", (e) => {
        const target = e.target;
        if (
          mobileNav.classList.contains("open") &&
          target instanceof Node &&
          !mobileNav.contains(target) &&
          !burgerBtn.contains(target)
        ) {
          closeMobileNav(mobileNav, burgerBtn);
        }
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && mobileNav.classList.contains("open")) {
          closeMobileNav(mobileNav, burgerBtn);
        }
      });
    }

    function updateLoyaltyHighlight(points) {
      const textEl = document.getElementById("loyalty-highlight-text");
      const progressValueEl = document.getElementById("loyalty-progress-value");
      const progressFillEl = document.getElementById("loyalty-progress-fill");
      const currentPointsEl = document.getElementById("loyalty-current-points");
      const remainingPointsEl = document.getElementById("loyalty-remaining-points");
      const nextGoalEl = document.getElementById("loyalty-next-goal");
      const rewardLabelEl = document.getElementById("loyalty-reward-label");

      if (typeof points !== "number" || !Number.isFinite(points)) {
        if (textEl) {
          textEl.textContent = "Connectez-vous pour voir combien de points il vous reste avant votre séance offerte.";
        }
        if (progressValueEl) {
          progressValueEl.textContent = "0 / 100";
        }
        if (progressFillEl) {
          progressFillEl.style.width = "0%";
        }
        if (currentPointsEl) {
          currentPointsEl.textContent = "0";
        }
        if (remainingPointsEl) {
          remainingPointsEl.textContent = "100";
        }
        if (nextGoalEl) {
          nextGoalEl.textContent = "100 points";
        }
        if (rewardLabelEl) {
          rewardLabelEl.textContent = "Séance offerte";
        }
        return;
      }

      const safePoints = Math.max(0, Math.floor(points));
      const progress = Math.min(safePoints, 100);
      const remaining = Math.max(0, 100 - safePoints);

      if (textEl) {
        if (remaining === 0) {
          textEl.textContent = "Bravo ! Vous avez atteint le palier fidélité. Votre prochaine séance offerte est débloquée.";
        } else if (remaining === 1) {
          textEl.textContent = "Plus qu’1 point avant de débloquer votre prochaine séance offerte.";
        } else {
          textEl.textContent = `Plus que ${remaining} points avant de débloquer votre prochaine séance offerte.`;
        }
      }

      if (progressValueEl) {
        progressValueEl.textContent = `${progress} / 100`;
      }

      if (progressFillEl) {
        progressFillEl.style.width = `${progress}%`;
      }

      if (currentPointsEl) {
        currentPointsEl.textContent = String(safePoints);
      }

      if (remainingPointsEl) {
        remainingPointsEl.textContent = String(remaining);
      }

      if (nextGoalEl) {
        nextGoalEl.textContent = remaining === 0 ? "Palier atteint" : "100 points";
      }

      if (rewardLabelEl) {
        rewardLabelEl.textContent = "Séance offerte";
      }
    }

