  <style>
    :root {
      --sb-bg-main: #050814;
      --sb-bg-deep: #020617;
      --sb-bg-soft: #030712;
      --sb-card: #050b18;
      --sb-text-main: #f9fafb;
      --sb-text-muted: #d1d5db;
      --sb-red: #c94c35;
      --sb-orange: #f97316;
      --sb-border-soft: rgba(148, 163, 184, 0.35);
      --sb-container-width: 1180px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: "Montserrat", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--sb-text-main);
      background:
        radial-gradient(circle at 10% 0%, rgba(107, 18, 32, 0.65), transparent 55%),
        radial-gradient(circle at 80% 10%, rgba(30, 64, 175, 0.7), transparent 60%),
        linear-gradient(145deg, #020617 0, #020617 40%, var(--sb-bg-main) 100%);
      min-height: 100vh;
      overflow-x: hidden;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    h1, h2, h3, h4 {
      font-family: "League Spartan", system-ui, sans-serif;
      letter-spacing: 0.03em;
      margin: 0;
    }

    .sr-only {
      position: absolute !important;
      width: 1px !important;
      height: 1px !important;
      padding: 0 !important;
      margin: -1px !important;
      overflow: hidden !important;
      clip: rect(0, 0, 0, 0) !important;
      white-space: nowrap !important;
      border: 0 !important;
    }

    .container {
      max-width: var(--sb-container-width);
      margin: 0 auto;
      padding: 0 24px;
    }

    .site-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 50;
      background: #020617;
      color: #fff;
      box-shadow: 0 14px 30px rgba(0, 0, 0, 0.75);
      border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    }

    .header-inner {
      max-width: var(--sb-container-width);
      margin: 0 auto;
      padding: 12px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      flex-wrap: nowrap;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }

    .brand-logo {
      width: 110px;
      height: auto;
      border-radius: 999px;
      display: block;
      object-fit: contain;
      filter:
        drop-shadow(0 0 12px rgba(255, 255, 255, 0.16))
        drop-shadow(0 0 20px rgba(201, 76, 53, 0.6));
    }

    .brand-text {
      font-family: "League Spartan", system-ui, sans-serif;
      font-weight: 600;
      letter-spacing: 0.15em;
      font-size: 26px;
      color: #f9fafb;
      text-transform: uppercase;
      white-space: nowrap;
      display: flex;
      align-items: center;
    }

    nav.main-nav {
      flex: 1;
      display: flex;
      justify-content: center;
      min-width: 0;
    }

    .main-nav ul {
      list-style: none;
      display: flex;
      gap: 32px;
      margin: 0;
      padding: 0;
      font-size: 14px;
    }

    .main-nav a {
      font-weight: 600;
      letter-spacing: 0.3px;
      color: #ffffff;
      position: relative;
      padding-bottom: 4px;
      white-space: nowrap;
    }

    .main-nav a::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: 0;
      width: 0%;
      height: 2px;
      background: linear-gradient(90deg, #ff6930, #ffb96f);
      transition: width 0.3s ease;
      border-radius: 6px;
    }

    .main-nav a:hover::after,
    .main-nav a:focus-visible::after,
    .main-nav a[aria-current="page"]::after {
      width: 100%;
    }

    .main-nav a:hover,
    .main-nav a:focus-visible,
    .main-nav a[aria-current="page"] {
      color: #ffb96f;
      transition: 0.25s ease;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }

    .nav-cta {
      background: var(--sb-red);
      padding: 8px 22px;
      border-radius: 999px;
      font-weight: 600;
      font-size: 14px;
      color: #f9fafb;
      white-space: nowrap;
      box-shadow:
        0 0 0 1px rgba(249, 250, 251, 0.08),
        0 10px 28px rgba(0, 0, 0, 0.7);
      transition: background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    }

    .nav-cta:hover,
    .nav-cta:focus-visible {
      background: #d55a40;
      transform: translateY(-1px);
      box-shadow:
        0 0 0 1px rgba(249, 250, 251, 0.18),
        0 16px 38px rgba(0, 0, 0, 0.9);
    }

    .cart-icon {
      width: 36px;
      height: 36px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.25);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      cursor: pointer;
      position: relative;
      background: radial-gradient(circle at 30% 0%, rgba(248, 250, 252, 0.16), rgba(15, 23, 42, 0.85));
      backdrop-filter: blur(6px);
    }

    #cart-count {
      position: absolute;
      top: -6px;
      right: -6px;
      background: var(--sb-red);
      color: #fff;
      border-radius: 999px;
      font-size: 10px;
      padding: 2px 5px;
      min-width: 18px;
      text-align: center;
    }

    #cart-count:empty {
      display: none;
    }

    .burger-button {
      display: none;
      width: 36px;
      height: 36px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.25);
      background: transparent;
      color: #fff;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 20px;
    }

    .mobile-nav {
      display: none;
      position: fixed;
      top: 74px;
      left: 0;
      right: 0;
      background: #020617;
      padding: 12px 24px 16px;
      z-index: 40;
      border-bottom: 1px solid rgba(255, 255, 255, 0.15);
      box-shadow: 0 14px 30px rgba(0, 0, 0, 0.45);
    }

    .mobile-nav ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
      font-size: 15px;
    }

    .mobile-nav a {
      color: #fff;
    }

    .mobile-nav.open {
      display: block;
    }

    @media (max-width: 900px) {
      .header-inner {
        padding: 8px 10px;
        gap: 8px;
      }

      nav.main-nav {
        display: none;
      }

      .brand-logo {
        width: 58px;
      }

      .brand-text {
        font-size: 15px;
        letter-spacing: 0.11em;
      }

      .nav-cta {
        padding: 6px 12px;
        font-size: 11px;
      }

      .cart-icon,
      .burger-button {
        width: 32px;
        height: 32px;
        font-size: 18px;
      }

      .burger-button {
        display: flex;
      }
    }

    @media (max-width: 480px) {
      .header-inner {
        padding: 8px 8px;
        gap: 6px;
      }

      .brand-logo {
        width: 50px;
      }

      .brand-text {
        font-size: 13px;
        letter-spacing: 0.09em;
      }

      .nav-cta {
        padding: 5px 10px;
        font-size: 10px;
      }

      .cart-icon,
      .burger-button {
        width: 30px;
        height: 30px;
        font-size: 16px;
      }
    }

    #account {
      position: relative;
      padding: 10rem 0 64px;
      background:
        radial-gradient(circle at 25% 0%, rgba(201, 76, 53, 0.35), transparent 55%),
        radial-gradient(circle at 80% 0%, rgba(37, 99, 235, 0.45), transparent 60%),
        #050814;
      color: var(--sb-text-main);
      overflow: hidden;
    }

    #account::before {
      content: "★";
      position: absolute;
      top: 16%;
      left: 8%;
      font-size: 32px;
      color: rgba(148, 163, 184, 0.1);
      pointer-events: none;
    }

    #account::after {
      content: "♪";
      position: absolute;
      bottom: 14%;
      right: 8%;
      font-size: 30px;
      color: rgba(148, 163, 184, 0.08);
      pointer-events: none;
    }

    .account-header {
      max-width: 640px;
      margin: 0 auto 32px;
      text-align: center;
    }

    .account-header-eyebrow {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: #9ca3af;
      margin-bottom: 8px;
    }

    .account-header h1 {
      font-size: 30px;
      margin-bottom: 8px;
    }

    .account-header p {
      margin: 0;
      font-size: 14px;
      color: rgba(249, 250, 251, 0.85);
    }

    .account-layout {
      max-width: 760px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
      gap: 1.5rem;
      align-items: stretch;
    }

    @media (max-width: 820px) {
      .account-layout {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    .card {
      background: var(--sb-card);
      border-radius: 24px;
      padding: 1.75rem 1.9rem;
      box-shadow:
        0 24px 60px rgba(0, 0, 0, 0.9),
        0 0 0 1px rgba(148, 163, 184, 0.3);
      border: 1px solid rgba(255, 255, 255, 0.2);
      position: relative;
      overflow: hidden;
    }

    .card::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: radial-gradient(circle at 0 0, rgba(148, 163, 184, 0.1), transparent 60%);
      opacity: 0.6;
      mix-blend-mode: soft-light;
    }

    .card > * {
      position: relative;
      z-index: 1;
    }

    .account-main-card h2 {
      font-size: 22px;
      margin-bottom: 6px;
    }

    .account-field-label {
      font-size: 13px;
      color: var(--sb-text-muted);
      margin-bottom: 2px;
    }

    .account-field-value {
      font-size: 15px;
      font-weight: 600;
      margin-bottom: 10px;
      word-break: break-word;
    }

    .badge-points {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.9);
      border: 1px solid rgba(255, 255, 255, 0.2);
      font-size: 12px;
      margin-top: 6px;
      flex-wrap: wrap;
    }

    .badge-points span:first-child {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 20px;
      height: 20px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--sb-red), var(--sb-orange));
      font-size: 12px;
      flex-shrink: 0;
    }

    .account-subtext {
      font-size: 12px;
      color: var(--sb-text-muted);
      margin-top: 8px;
    }

    .logout-row {
      margin-top: 18px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .logout-btn {
      border: none;
      border-radius: 999px;
      padding: 0.55rem 1.2rem;
      background: #111827;
      color: #f9fafb;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.35),
        0 10px 28px rgba(0, 0, 0, 0.8);
      transition: background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    }

    .logout-btn:hover,
    .logout-btn:focus-visible {
      background: #1f2937;
      transform: translateY(-1px);
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.55),
        0 14px 34px rgba(0, 0, 0, 0.95);
    }

    .account-message {
      font-size: 12px;
      color: #fca5a5;
      min-height: 16px;
      margin: 4px 0 10px;
    }

    .account-message.ok {
      color: #bbf7d0;
    }

    .account-message.info {
      color: #93c5fd;
    }

    .reservations-block {
      margin-top: 18px;
      font-size: 13px;
    }

    .reservations-list {
      margin-top: 6px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .reservations-empty {
      margin: 0;
      font-size: 12px;
      color: var(--sb-text-muted);
    }

    .reservation-item {
      background: #020617;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.25);
      padding: 9px 11px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .reservation-main-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .reservation-date {
      font-weight: 600;
      font-size: 13px;
    }

    .reservation-meta {
      font-size: 12px;
      color: var(--sb-text-muted);
      word-break: break-word;
    }

    .reservation-side {
      text-align: right;
      font-size: 12px;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 3px;
    }

    .reservation-price {
      font-weight: 600;
    }

    .reservation-status {
      padding: 2px 8px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.35);
      font-size: 11px;
      text-transform: capitalize;
    }

    .reservation-status-confirmed {
      border-color: rgba(52, 211, 153, 0.8);
      color: #6ee7b7;
    }

    .reservation-status-pending {
      border-color: rgba(251, 191, 36, 0.8);
      color: #facc15;
    }

    .reservation-status-annulee {
      border-color: rgba(248, 113, 113, 0.85);
      color: #fecaca;
    }

    .reservation-actions-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: flex-end;
      align-items: center;
      margin-top: 2px;
    }

    .reservation-action-btn {
      border: none;
      border-radius: 999px;
      padding: 6px 10px;
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.25),
        0 10px 28px rgba(0, 0, 0, 0.9);
      transition: transform 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
      white-space: nowrap;
    }

    .reservation-action-btn:hover,
    .reservation-action-btn:focus-visible {
      transform: translateY(-1px);
      filter: brightness(1.03);
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.35),
        0 16px 40px rgba(0, 0, 0, 1);
    }

    .reservation-qr-btn {
      background: linear-gradient(90deg, #1d4ed8, #4c1d95);
      color: #f9fafb;
    }

    .reservation-edit-btn {
      background: linear-gradient(90deg, #0f766e, #1d4ed8);
      color: #f9fafb;
    }

    .reservation-action-btn[disabled] {
      opacity: 0.55;
      cursor: not-allowed;
      transform: none;
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.15),
        0 6px 16px rgba(0, 0, 0, 0.45);
    }

    .reservation-refund-row {
      margin-top: 6px;
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      color: var(--sb-text-muted);
      flex-wrap: wrap;
    }

    .reservation-refund-btn {
      border: none;
      border-radius: 999px;
      padding: 5px 10px;
      background: linear-gradient(90deg, var(--sb-red), var(--sb-orange));
      color: #f9fafb;
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.18),
        0 10px 28px rgba(0, 0, 0, 0.9);
      transition: transform 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
      white-space: nowrap;
    }

    .reservation-refund-btn:hover,
    .reservation-refund-btn:focus-visible {
      transform: translateY(-1px);
      filter: brightness(1.03);
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.25),
        0 16px 40px rgba(0, 0, 0, 1);
    }

    .reservation-refund-btn[disabled] {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.18),
        0 6px 16px rgba(0, 0, 0, 0.5);
    }

    .loyalty-card h3 {
      font-size: 18px;
      margin-bottom: 6px;
    }

    .loyalty-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      padding: 4px 10px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.9);
      border: 1px solid rgba(255, 255, 255, 0.2);
      margin-bottom: 10px;
    }

    .loyalty-pill span:first-child {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--sb-red), var(--sb-orange));
      font-size: 11px;
    }

    .loyalty-card p {
      font-size: 12px;
      color: var(--sb-text-muted);
      margin-top: 0;
      margin-bottom: 8px;
    }

    .loyalty-highlight {
      font-size: 13px;
      margin-top: 4px;
      color: #f9fafb;
    }

    .loyalty-next {
      font-size: 12px;
      margin-top: 4px;
      color: #bfdbfe;
    }

    .account-cta {
      font-size: 12px;
      margin-top: 10px;
      color: #f97316;
    }

    .account-cta a {
      color: #f97316;
      text-decoration: underline;
    }

    .account-cta a:hover,
    .account-cta a:focus-visible {
      text-decoration: none;
    }

    .login-card-title {
      font-size: 18px;
      margin-bottom: 8px;
    }

    .login-description {
      font-size: 13px;
      color: var(--sb-text-muted);
      margin-bottom: 10px;
    }

    .login-field {
      margin-bottom: 8px;
      font-size: 13px;
    }

    .login-field label {
      display: block;
      margin-bottom: 3px;
      color: #e5e7eb;
      font-size: 12px;
    }

    .login-field input {
      width: 100%;
      font-family: inherit;
      font-size: 13px;
      color: #f9fafb;
      background: #020617;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.22);
      padding: 0.55rem 0.85rem;
      outline: none;
      transition: border-color 0.16s ease, box-shadow 0.16s ease;
    }

    .login-field input::placeholder {
      color: rgba(156, 163, 175, 0.9);
    }

    .login-field input:focus {
      border-color: var(--sb-orange);
      box-shadow:
        0 0 0 1px rgba(249, 115, 22, 0.8),
        0 0 22px rgba(249, 115, 22, 0.25);
    }

    .login-field input[aria-invalid="true"] {
      outline: 2px solid #ff6b6b;
