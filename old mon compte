    function parseDateOrNull(dateStr) {
      if (!dateStr) {
        return null;
      }

      const date = new Date(dateStr);
      if (Number.isNaN(date.getTime())) {
        return null;
      }
      return date;
    }

    function formatTime(date) {
      if (!(date instanceof Date) || Number.isNaN(date.getTime())) {
        return "";
      }

      return date
        .toLocaleTimeString("fr-FR", { hour: "2-digit", minute: "2-digit" })
        .replace(":", "h");
    }

    function formatReservationDate(dateStr) {
      const date = parseDateOrNull(dateStr);
      if (!date) {
        return sanitizeText(dateStr || "Date à confirmer", 80);
      }

      return date.toLocaleDateString("fr-FR", {
        weekday: "short",
        day: "2-digit",
        month: "short",
        year: "numeric"
      });
    }

    function formatReservationHoursFromReservation(reservation) {
      const startStr = reservation.start_time || reservation.datetime || null;
      const start = parseDateOrNull(startStr);

      if (!start) {
        return "";
      }

      const defaultDurationMs = 90 * 60 * 1000;
      let end = parseDateOrNull(reservation.end_time);

      if (!end) {
        end = new Date(start.getTime() + defaultDurationMs);
      }

      return `${formatTime(start)} - ${formatTime(end)}`;
    }

    function isRefundPossible(startTimeIso) {
      const start = parseDateOrNull(startTimeIso);
      if (!start) {
        return false;
      }

      const now = new Date();
      const diffMs = start.getTime() - now.getTime();
      const hoursBefore = diffMs / (1000 * 60 * 60);
      return hoursBefore >= 24;
    }

    function isModificationPossible(startTimeIso, statusRaw) {
      const start = parseDateOrNull(startTimeIso);
      if (!start) {
        return false;
      }

      const normalized = (statusRaw || "").toString().toLowerCase();
      const isConfirmed =
        normalized === "confirmed" ||
        normalized === "paid" ||
        normalized.includes("confirm") ||
        normalized.includes("payé") ||
        normalized.includes("paye");

      if (!isConfirmed) {
        return false;
      }

      const now = new Date();
      const diffHours = (start.getTime() - now.getTime()) / (1000 * 60 * 60);

      return diffHours >= MODIFICATION_DEADLINE_HOURS;
    }

    function getReservationIdForQr(reservation) {
      return reservation?.id || null;
    }

    function buildCheckUrlFromReservationId(id) {
      if (!id) {
        return null;
      }
      return `${CHECK_ENDPOINT}?id=${encodeURIComponent(String(id))}`;
    }

    function getReservationStatusClass(statusRaw) {
      const normalized = (statusRaw || "").toString().toLowerCase();

      if (
        normalized === "confirmed" ||
        normalized === "paid" ||
        normalized.includes("confirm") ||
        normalized.includes("payé") ||
        normalized.includes("paye")
      ) {
        return "reservation-status-confirmed";
      }

      if (normalized.includes("attente") || normalized === "pending") {
        return "reservation-status-pending";
      }

      if (
        normalized.includes("annul") ||
        normalized === "cancelled" ||
        normalized === "canceled"
      ) {
        return "reservation-status-annulee";
      }

      return "";
    }

    function buildReservationMetaText(reservation) {
      const metaPieces = [];
      const timeRange = formatReservationHoursFromReservation(reservation);
      const rawBoxName = reservation.box_name || reservation.box || reservation.box_id || "";
      const boxName = sanitizeText(rawBoxName, 80);

      if (timeRange) {
        metaPieces.push(timeRange);
      }

      if (boxName) {
        metaPieces.push(/^box/i.test(boxName) ? boxName : `Box ${boxName}`);
      }

      return metaPieces.join(" • ");
    }

    function createButton(classes, text, disabled = false) {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = classes;
      btn.textContent = text;
      if (disabled) btn.disabled = true;
      return btn;
    }

    function createReservationItemElement(reservation) {
      const item = document.createElement("div");
      item.className = "reservation-item";

      const startTimeIso = sanitizeText(reservation.start_time || reservation.datetime || "", 100);
      const date = formatReservationDate(reservation.date || startTimeIso);
      const metaText = buildReservationMetaText(reservation);
      const boxName = sanitizeText(reservation.box_name || reservation.box || reservation.box_id || "", 80);
      const montantRaw = reservation.montant || reservation.total || reservation.total_price || "";
      const montant = sanitizeText(montantRaw, 40);
      const statutRaw = sanitizeText((reservation.statut || reservation.status || "").toString(), 80);
      const statutClass = getReservationStatusClass(statutRaw);

      const reservationId = getReservationIdForQr(reservation);
      const checkUrl = buildCheckUrlFromReservationId(reservationId);
      const canShowQr = Boolean(checkUrl);

      const qrTitleParts = [];
      if (boxName) {
        qrTitleParts.push(/^box/i.test(boxName) ? boxName : `Box ${boxName}`);
      }
      qrTitleParts.push(date);

      const plageHeure = formatReservationHoursFromReservation(reservation);
      if (plageHeure) {
        qrTitleParts.push(plageHeure);
      }

      const qrTitle = qrTitleParts.join(" • ");

      const parsedStart = parseDateOrNull(startTimeIso);
      const hasValidStart = Boolean(parsedStart);
      const isInFuture = Boolean(parsedStart && parsedStart.getTime() > Date.now());
      const isFutureConfirmed = statutClass === "reservation-status-confirmed" && hasValidStart && isInFuture;
      const canRefund = isRefundPossible(startTimeIso);
      const canEdit = isModificationPossible(startTimeIso, statutRaw);

      const mainRow = document.createElement("div");
      mainRow.className = "reservation-main-row";

      const leftCol = document.createElement("div");
      const dateEl = document.createElement("div");
      dateEl.className = "reservation-date";
      dateEl.textContent = date;

      const metaEl = document.createElement("div");
      metaEl.className = "reservation-meta";
      metaEl.textContent = metaText;

      leftCol.appendChild(dateEl);
      leftCol.appendChild(metaEl);

      const rightCol = document.createElement("div");
      rightCol.className = "reservation-side";

      if (montant) {
        const priceEl = document.createElement("div");
        priceEl.className = "reservation-price";
        priceEl.textContent = `${montant} €`;
        rightCol.appendChild(priceEl);
      }

      if (statutRaw) {
        const statusEl = document.createElement("span");
        statusEl.className = `reservation-status ${statutClass}`.trim();
        statusEl.textContent = statutRaw;
        rightCol.appendChild(statusEl);
      }

      mainRow.appendChild(leftCol);
      mainRow.appendChild(rightCol);
      item.appendChild(mainRow);

      const actionsRow = document.createElement("div");
      actionsRow.className = "reservation-actions-row";

      const editBtn = createButton(
        "reservation-action-btn reservation-edit-btn",
        "Modifier",
        !canEdit
      );

      if (canEdit && reservation?.id) {
        editBtn.dataset.editReservationId = String(reservation.id);
      }

      const qrBtn = createButton(
        "reservation-action-btn reservation-qr-btn",
        canShowQr ? "Afficher le QR" : "QR indisponible",
        !canShowQr
      );

      if (canShowQr) {
        qrBtn.dataset.qrUrl = checkUrl;
        qrBtn.dataset.qrTitle = qrTitle;
      }

      actionsRow.appendChild(editBtn);
      actionsRow.appendChild(qrBtn);
      item.appendChild(actionsRow);

      if (isFutureConfirmed) {
        const refundRow = document.createElement("div");
        refundRow.className = "reservation-refund-row";

        const infoSpan = document.createElement("span");
        infoSpan.textContent = canRefund
          ? "Remboursement possible jusqu'à 24h avant la séance."
          : "Le remboursement n'est plus possible (moins de 24h avant la séance).";

        refundRow.appendChild(infoSpan);

        const refundBtn = createButton(
          "reservation-refund-btn",
          "Demander un remboursement",
          !(canRefund && reservation?.id)
        );

        if (reservation?.id) {
          refundBtn.dataset.reservationId = String(reservation.id);
          refundBtn.dataset.startTime = startTimeIso;
        }

        refundRow.appendChild(refundBtn);
        item.appendChild(refundRow);
      }

      return item;
    }

    function renderReservations(reservations) {
      const listEl = document.getElementById("reservations-list");
      if (!listEl) {
        return;
      }

      listEl.innerHTML = "";

      if (!Array.isArray(reservations) || reservations.length === 0) {
        const p = document.createElement("p");
        p.className = "reservations-empty";
        p.textContent = "Aucune réservation pour le moment.";
        listEl.appendChild(p);
        return;
      }

      for (const reservation of reservations) {
        const item = createReservationItemElement(reservation);
        listEl.appendChild(item);
      }
    }

    async function drawQrToCanvas(text) {
      const canvas = document.getElementById("qr-canvas");
      if (!canvas || !globalThis.QRCode) return;

      await globalThis.QRCode.toCanvas(canvas, text, {
        width: 320,
        margin: 1,
        color: {
          dark: "#000000",
          light: "#ffffff"
        }
      });
    }

    async function openQrModal(checkUrl, subtitleText) {
      const modal = document.getElementById("qr-modal");
      const subtitle = document.getElementById("qr-modal-subtitle");

      if (!modal) {
        return;
      }

      if (subtitle && subtitleText) {
        subtitle.textContent = sanitizeText(subtitleText, 200);
      }

      await drawQrToCanvas(checkUrl);

      if (typeof modal.showModal === "function") {
        modal.showModal();
      } else {
        modal.setAttribute("open", "open");
      }
    }

    function closeQrModal() {
      const modal = document.getElementById("qr-modal");
      const canvas = document.getElementById("qr-canvas");

      if (!modal) {
        return;
      }

      if (typeof modal.close === "function" && modal.open) {
        modal.close();
      } else {
        modal.removeAttribute("open");
      }

      if (canvas) {
        const ctx = canvas.getContext("2d");
        if (ctx) {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
        }
      }
    }

    async function loadReservations() {
      const token = getStoredToken();
      const listEl = document.getElementById("reservations-list");
      const refundMsgEl = document.getElementById("refund-message");

      if (!listEl) {
        return;
      }

      if (refundMsgEl) {
        refundMsgEl.textContent = "";
        refundMsgEl.className = "account-message";
      }

      if (!token) {
        setReservationsNotLogged();
        return;
      }

      listEl.innerHTML = "";
      const loading = document.createElement("p");
      loading.className = "reservations-empty";
      loading.textContent = "Chargement de vos réservations...";
      listEl.appendChild(loading);

      try {
        const response = await fetchWithAuth(API_BASE + "/api/my-reservations");

        if (response.status === 401 || response.status === 403) {
          showNotLoggedState();
          return;
        }

        if (!response.ok) {
          console.error("Erreur chargement réservations", response.status);
          listEl.innerHTML = "";
          const p = document.createElement("p");
          p.className = "reservations-empty";
          p.textContent = "Impossible de charger vos réservations pour le moment.";
          listEl.appendChild(p);
          return;
        }

        const data = await safeJson(response);
        const reservations = Array.isArray(data) ? data : (data.reservations || []);
        renderReservations(reservations);
      } catch (err) {
        console.error(err);
        listEl.innerHTML = "";
        const p = document.createElement("p");
        p.className = "reservations-empty";
        p.textContent = "Erreur de chargement de vos réservations.";
        listEl.appendChild(p);
      }
    }

    async function loadProfile() {
      const token = getStoredToken();
      const loginCard = document.getElementById("login-card");
      const notLoggedCta = document.getElementById("not-logged-cta");
      const msgEl = document.getElementById("account-message");

      if (!token) {
        showNotLoggedState();
        return;
      }

      if (msgEl) {
        msgEl.textContent = "Chargement de votre espace client...";
        msgEl.className = "account-message info";
      }

      try {
        const response = await fetchWithAuth(API_BASE + "/api/me");

        if (response.status === 401 || response.status === 403) {
          showNotLoggedState();
          return;
        }

        if (!response.ok) {
          if (msgEl) {
            msgEl.textContent = "Impossible de charger votre espace client pour le moment.";
            msgEl.className = "account-message";
          }
          return;
        }

        const user = await safeJson(response);

        const emailEl = document.getElementById("user-email");
        const pointsEl = document.getElementById("user-points");

        if (emailEl) {
          emailEl.textContent = sanitizeText(user.email || "—", 254);
        }

        if (pointsEl) {
          const safePoints = typeof user.points === "number" && Number.isFinite(user.points)
            ? Math.max(0, Math.floor(user.points))
            : 0;
          pointsEl.textContent = String(safePoints);
        }

        if (msgEl) {
          msgEl.textContent = "Bienvenue dans votre espace client.";
          msgEl.className = "account-message ok";
        }

        if (loginCard) {
          loginCard.style.display = "none";
        }

        if (notLoggedCta) {
          notLoggedCta.style.display = "none";
        }

        updateLoyaltyHighlight(user.points ?? 0);
        loadReservations();
      } catch (err) {
        console.error("Erreur /api/me :", err);

        if (msgEl) {
          msgEl.textContent = "Erreur de chargement. Merci de réessayer dans quelques instants.";
          msgEl.className = "account-message";
        }
      }
    }

    function setLoginMessage(loginMsgEl, text, type = "error") {
      if (!loginMsgEl) {
        return;
      }

      loginMsgEl.textContent = text || "";
      loginMsgEl.className = "login-message";

      if (type === "ok") {
        loginMsgEl.classList.add("ok");
      } else if (type === "info") {
        loginMsgEl.classList.add("info");
      }
    }

    function setAuthButtonsLoading(isLoading) {
      const loginBtn = document.getElementById("login-submit-btn");
      const createBtn = document.getElementById("create-account-btn");

      if (loginBtn) {
        if (!loginBtn.dataset.defaultText) {
          loginBtn.dataset.defaultText = loginBtn.textContent;
        }
        loginBtn.disabled = isLoading;
        loginBtn.textContent = isLoading ? "Chargement..." : loginBtn.dataset.defaultText;
      }

      if (createBtn) {
        if (!createBtn.dataset.defaultText) {
          createBtn.dataset.defaultText = createBtn.textContent;
        }
        createBtn.disabled = isLoading;
        createBtn.textContent = isLoading ? "Chargement..." : createBtn.dataset.defaultText;
      }
    }

    function clearLoginFieldErrors() {
      const emailEl = document.getElementById("login-email");
      const passEl = document.getElementById("login-password");

      if (emailEl) emailEl.removeAttribute("aria-invalid");
      if (passEl) passEl.removeAttribute("aria-invalid");
    }

    function getLoginCredentials() {
      const emailEl = document.getElementById("login-email");
      const passEl = document.getElementById("login-password");

      return {
        email: normalizeEmail(emailEl?.value || ""),
        password: passEl?.value || ""
      };
    }

    async function postJson(url, payload) {
      const response = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });

      const data = await safeJson(response);
      return { response, data };
    }

    async function doLogin(email, password) {
      const { response, data } = await postJson(API_BASE + "/api/login", { email, password });
      const token = data?.token;

      return {
        ok: response.ok && Boolean(token),
        token,
        error: data?.error
      };
    }

    async function doRegister(email, password) {
      const { response, data } = await postJson(API_BASE + "/api/register", { email, password });

      return {
        ok: response.ok,
        error: data?.error
      };
    }

    async function registerThenLogin(email, password) {
      const registerResult = await doRegister(email, password);

      if (!registerResult.ok) {
        return {
          ok: false,
          step: "register",
          error: registerResult.error || "Erreur lors de la création du compte."
        };
      }

      const loginResult = await doLogin(email, password);

      if (!loginResult.ok) {
        return {
          ok: false,
          step: "login",
          error: "Compte créé, mais la connexion a échoué."
        };
      }

      return {
        ok: true,
        token: loginResult.token
      };
    }

    function initLoginForm() {
      const loginForm = document.getElementById("login-form");
      const loginMsg = document.getElementById("login-message");
      const createBtn = document.getElementById("create-account-btn");

      if (!loginForm) {
        return;
      }

      loginForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        clearLoginFieldErrors();
        setLoginMessage(loginMsg, "", "error");

        const emailEl = document.getElementById("login-email");
        const passEl = document.getElementById("login-password");
        const { email, password } = getLoginCredentials();

        if (!isValidEmail(email)) {
          if (emailEl) emailEl.setAttribute("aria-invalid", "true");
          setLoginMessage(loginMsg, "Merci d’entrer une adresse e-mail valide.", "error");
          return;
        }

        if (!password) {
          if (passEl) passEl.setAttribute("aria-invalid", "true");
          setLoginMessage(loginMsg, "Merci de renseigner votre mot de passe.", "error");
          return;
        }

        setAuthButtonsLoading(true);
        setLoginMessage(loginMsg, "Connexion en cours...", "info");

        try {
          const result = await doLogin(email, password);

          if (!result.ok) {
            setLoginMessage(
              loginMsg,
              result.error || "Erreur de connexion. Vérifiez vos identifiants.",
              "error"
            );
            return;
          }

          localStorage.setItem("token", result.token);
          setLoginMessage(loginMsg, "Connexion réussie.", "ok");
          loadProfile();
        } catch (err) {
          console.error(err);
          setLoginMessage(loginMsg, "Erreur réseau. Veuillez réessayer.", "error");
        } finally {
          setAuthButtonsLoading(false);
        }
      });

      if (createBtn) {
        createBtn.addEventListener("click", async () => {
          clearLoginFieldErrors();
          setLoginMessage(loginMsg, "", "error");

          const emailEl = document.getElementById("login-email");
          const passEl = document.getElementById("login-password");
          const { email, password } = getLoginCredentials();

          if (!isValidEmail(email)) {
            if (emailEl) emailEl.setAttribute("aria-invalid", "true");
            setLoginMessage(loginMsg, "Merci d’entrer une adresse e-mail valide.", "error");
            return;
          }

          if (!password || password.length < 6) {
            if (passEl) passEl.setAttribute("aria-invalid", "true");
            setLoginMessage(loginMsg, "Choisissez un mot de passe d’au moins 6 caractères.", "error");
            return;
          }

          setAuthButtonsLoading(true);
          setLoginMessage(loginMsg, "Création du compte en cours...", "info");

          try {
            const result = await registerThenLogin(email, password);

            if (!result.ok) {
              setLoginMessage(
                loginMsg,
                result.error || "Erreur lors de la création du compte.",
                "error"
              );
              return;
            }

            localStorage.setItem("token", result.token);
            setLoginMessage(loginMsg, "Compte créé et connecté.", "ok");
            loadProfile();
          } catch (err) {
            console.error(err);
            setLoginMessage(loginMsg, "Erreur réseau. Veuillez réessayer.", "error");
          } finally {
            setAuthButtonsLoading(false);
          }
        });
      }

      const emailEl = document.getElementById("login-email");
      const passEl = document.getElementById("login-password");
      if (emailEl) {
        emailEl.addEventListener("input", () => emailEl.removeAttribute("aria-invalid"));
      }
      if (passEl) {
        passEl.addEventListener("input", () => passEl.removeAttribute("aria-invalid"));
      }
    }

    function initLogout() {
      const logoutBtn = document.getElementById("logout-btn");
      if (!logoutBtn) {
        return;
      }

      logoutBtn.addEventListener("click", () => {
        clearStoredToken();

        const msgEl = document.getElementById("account-message");
        const refundMsgEl = document.getElementById("refund-message");

        if (msgEl) {
          msgEl.textContent = "Vous avez été déconnecté.";
          msgEl.className = "account-message";
        }

        if (refundMsgEl) {
          refundMsgEl.textContent = "";
          refundMsgEl.className = "account-message";
        }

        showNotLoggedState();
      });
    }

    function initRefundButtons() {
      const listEl = document.getElementById("reservations-list");
      const refundMsgEl = document.getElementById("refund-message");

      if (!listEl || !refundMsgEl) {
        return;
      }

      listEl.addEventListener("click", async (e) => {
        const target = e.target;
        if (!(target instanceof Element)) {
          return;
        }

        const btn = target.closest(".reservation-refund-btn");
        if (!btn) {
          return;
        }

        const reservationId = sanitizeText(btn.dataset.reservationId || "", 100);
        const startTime = sanitizeText(btn.dataset.startTime || "", 100);
        const token = getStoredToken();

        refundMsgEl.className = "account-message";
        refundMsgEl.textContent = "";

        if (!token) {
          refundMsgEl.textContent = "Vous devez être connecté pour demander un remboursement.";
          return;
        }

        if (!reservationId) {
          refundMsgEl.textContent = "Réservation introuvable.";
          return;
        }

        if (!isRefundPossible(startTime)) {
          refundMsgEl.textContent =
            "Le remboursement n'est plus possible (moins de 24h avant la séance).";
          return;
        }

        btn.disabled = true;
        refundMsgEl.textContent = "Demande de remboursement en cours...";
        refundMsgEl.className = "account-message info";

        try {
          const response = await fetch(API_BASE + "/api/refund-reservation", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              ...getAuthHeaders()
            },
            body: JSON.stringify({ reservationId })
          });

          const data = await safeJson(response);

          if (response.status === 401 || response.status === 403) {
            showNotLoggedState();
            return;
          }

          if (!response.ok || data.success !== true) {
            btn.disabled = false;
            refundMsgEl.textContent =
              data.error || "Impossible de procéder au remboursement.";
            refundMsgEl.className = "account-message";
            return;
          }

          refundMsgEl.textContent =
            "Remboursement effectué ou en cours de traitement. Votre réservation est annulée.";
          refundMsgEl.className = "account-message ok";
          loadReservations();
        } catch (err) {
          console.error(err);
          btn.disabled = false;
          refundMsgEl.textContent = "Erreur réseau. Veuillez réessayer.";
          refundMsgEl.className = "account-message";
        }
      });
    }

    function goToReservationEditPage(reservation) {
      if (!reservation || typeof reservation !== "object") {
        return;
      }

      try {
        sessionStorage.setItem("reservation_to_edit", JSON.stringify(reservation));
      } catch (error) {
        console.error("Impossible de stocker reservation_to_edit :", error);
      }

      const reservationId = reservation.id ? encodeURIComponent(String(reservation.id)) : "";
      const targetUrl = reservationId
        ? `modifier-reservation.html?reservationId=${reservationId}`
        : "modifier-reservation.html";

      window.location.href = targetUrl;
    }

    function initEditReservationButtons() {
      const listEl = document.getElementById("reservations-list");
      if (!listEl) {
        return;
      }

      listEl.addEventListener("click", async (e) => {
        const target = e.target;
        if (!(target instanceof Element)) {
          return;
        }

        const editBtn = target.closest(".reservation-edit-btn");
        if (!editBtn || editBtn.hasAttribute("disabled")) {
          return;
        }

        const reservationId = sanitizeText(editBtn.dataset.editReservationId || "", 100);
        if (!reservationId) {
          return;
        }

        const token = getStoredToken();
        if (!token) {
          return;
        }

        try {
          const response = await fetchWithAuth(API_BASE + "/api/my-reservations");

          if (response.status === 401 || response.status === 403) {
            showNotLoggedState();
            return;
          }

          if (!response.ok) {
            console.error("Impossible de recharger les réservations avant modification :", response.status);
            return;
          }

          const data = await safeJson(response);
          const reservations = Array.isArray(data) ? data : (data.reservations || []);
          const reservation = reservations.find((item) => String(item.id) === String(reservationId));

          if (!reservation) {
            console.error("Réservation introuvable pour modification :", reservationId);
            return;
          }

          goToReservationEditPage(reservation);
        } catch (error) {
          console.error("Erreur ouverture page modification réservation :", error);
        }
      });
    }

    function initQrActions() {
      const listEl = document.getElementById("reservations-list");
      const closeBtn = document.getElementById("qr-close-btn");
      const modal = document.getElementById("qr-modal");

      if (closeBtn) {
        closeBtn.addEventListener("click", closeQrModal);
      }

      if (modal) {
        modal.addEventListener("click", (e) => {
          const rect = modal.getBoundingClientRect();
          const isInDialog =
            rect.top <= e.clientY &&
            e.clientY <= rect.top + rect.height &&
            rect.left <= e.clientX &&
            e.clientX <= rect.left + rect.width;

          if (!isInDialog) {
            closeQrModal();
          }
        });

        modal.addEventListener("cancel", (e) => {
          e.preventDefault();
          closeQrModal();
        });
      }

      document.addEventListener("keydown", (e) => {
        if (e.key !== "Escape") {
          return;
        }
        if (!modal || !modal.open) {
          return;
        }
        closeQrModal();
      });

      if (!listEl) {
        return;
      }

      listEl.addEventListener("click", async (e) => {
        const target = e.target;
        if (!(target instanceof Element)) {
          return;
        }

        const qrBtn = target.closest(".reservation-qr-btn");
        if (!qrBtn || qrBtn.hasAttribute("disabled")) {
          return;
        }

        const qrUrl = sanitizeText(qrBtn.dataset.qrUrl || "", 500);
        const qrTitle = sanitizeText(qrBtn.dataset.qrTitle || "", 200);
        const title = qrTitle || "Présentez ce QR code à l’entrée.";

        if (qrUrl) {
          await openQrModal(qrUrl, title);
        }
      });
    }

    function setNewsletterMessage(messageBox, message, color) {
      if (!messageBox) return;
      messageBox.style.color = color;
      messageBox.textContent = message;
    }

    function setNewsletterLoading(submitBtn, isLoading) {
      if (!submitBtn) return;

      if (!submitBtn.dataset.defaultText) {
        submitBtn.dataset.defaultText = submitBtn.textContent || "S'abonner aux actualités";
      }

      submitBtn.disabled = isLoading;
      submitBtn.textContent = isLoading ? "Envoi..." : submitBtn.dataset.defaultText;
      submitBtn.setAttribute("aria-busy", String(isLoading));
    }

    function isDuplicateNewsletterError(error) {
      return Boolean(
        error &&
        (
          error.code === "23505" ||
          (typeof error.message === "string" && error.message.includes("duplicate key value"))
        )
      );
    }

    async function handleNewsletterSubmit() {
      const emailInput = document.getElementById("newsletter-email");
      const honeypotInput = document.getElementById("newsletter-company");
      const submitBtn = document.getElementById("newsletter-submit");
      const messageBox = document.getElementById("newsletter-message");

      if (!(emailInput instanceof HTMLInputElement) || !submitBtn || !messageBox) {
        return;
      }

      if (!supabaseClient) {
        setNewsletterMessage(messageBox, "Le service newsletter est momentanément indisponible.", "#ff6b6b");
        return;
      }

      const email = normalizeEmail(emailInput.value);
      const honeypotValue = sanitizeText(honeypotInput?.value || "", 100);

      emailInput.removeAttribute("aria-invalid");

      if (honeypotValue) {
        setNewsletterMessage(messageBox, "Merci !", "#38bdf8");
        return;
      }

      if (!isValidEmail(email)) {
        emailInput.setAttribute("aria-invalid", "true");
        setNewsletterMessage(messageBox, "Veuillez entrer une adresse e-mail valide.", "#ff6b6b");
        return;
      }

      setNewsletterLoading(submitBtn, true);
      setNewsletterMessage(messageBox, "Envoi en cours...", "#e5e7eb");

      try {
        const { error } = await supabaseClient
          .from("newsletter_subscriptions")
          .insert([{ email }]);

        if (error) {
          console.error("Erreur newsletter :", error);

          if (isDuplicateNewsletterError(error)) {
            setNewsletterMessage(messageBox, "Vous êtes déjà inscrit à la newsletter.", "#38bdf8");
          } else {
            setNewsletterMessage(messageBox, "Une erreur est survenue. Merci de réessayer dans quelques instants.", "#ff6b6b");
          }
          return;
        }

        setNewsletterMessage(messageBox, "Merci ! Vous êtes inscrit.", "#38bdf8");
        emailInput.value = "";
        if (honeypotInput) honeypotInput.value = "";
      } catch (error) {
        console.error("Erreur newsletter :", error);
        setNewsletterMessage(messageBox, "Erreur réseau. Merci de réessayer.", "#ff6b6b");
      } finally {
        setNewsletterLoading(submitBtn, false);
      }
    }

    function initNewsletter() {
      try {
        if (globalThis.supabase) {
          supabaseClient = globalThis.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
        }
      } catch (error) {
        console.error("Erreur initialisation Supabase :", error);
        supabaseClient = null;
      }

      const emailInput = document.getElementById("newsletter-email");
      const submitBtn = document.getElementById("newsletter-submit");

      if (!emailInput || !submitBtn) {
        return;
      }

      submitBtn.addEventListener("click", handleNewsletterSubmit);

      emailInput.addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
          event.preventDefault();
          handleNewsletterSubmit();
        }
      });

      emailInput.addEventListener("input", () => {
        emailInput.removeAttribute("aria-invalid");
      });
    }

    document.addEventListener("DOMContentLoaded", () => {
      initMobileMenu();
      updateCartIcon();
      initLoginForm();
      initLogout();
      initRefundButtons();
      initEditReservationButtons();
      initQrActions();
      initNewsletter();
      loadProfile();
    });
  </script>
</body>
