<section class="singbox-passes" aria-labelledby="passes-title">
  <div class="passes-header">
    <p class="passes-kicker">Cartes Singbox</p>
    <h2 id="passes-title">Choisissez la carte qui vous correspond</h2>
    <p class="passes-subtitle">
      Profitez de tarifs avantageux sur vos réservations, selon vos créneaux préférés.
    </p>
  </div>

  <div class="passes-grid">
    <!-- Carte avant 15h -->
    <article class="pass-card pass-card--highlight">
      <div class="pass-badge">Offre lancement</div>

      <h3>Carte 10 places avant 15h</h3>

      <div class="pass-price">
        <span class="pass-price-value">69€</span>
        <span class="pass-price-note">pour 10 places</span>
      </div>

      <p class="pass-description">
        Idéale pour profiter de Singbox en journée à prix réduit.
      </p>

      <ul class="pass-features">
        <li>Valable avant 15h</li>
        <li>1 place = 1 personne</li>
        <li>Déduction automatique à chaque réservation</li>
        <li>Parfait pour les groupes réguliers</li>
      </ul>

      <button
        class="pass-button"
        type="button"
        data-pass-name="Carte 10 places avant 15h"
        data-pass-price="69€"
        data-pass-rules="Valable sur les créneaux avant 15h uniquement. 1 place = 1 personne."
      >
        Acheter cette carte
      </button>
    </article>

    <!-- Carte après 15h -->
    <article class="pass-card">
      <div class="pass-badge pass-badge--dark">Semaine uniquement</div>

      <h3>Carte 10 places après 15h</h3>

      <div class="pass-price">
        <span class="pass-price-value">89€</span>
        <span class="pass-price-note">pour 10 places</span>
      </div>

      <p class="pass-description">
        Pensée pour les réservations en semaine, après 15h, hors créneaux les plus demandés.
      </p>

      <ul class="pass-features">
        <li>Valable après 15h en semaine</li>
        <li>Hors vendredi soir</li>
        <li>Hors week-end</li>
        <li>1 place = 1 personne</li>
      </ul>

      <button
        class="pass-button pass-button--secondary"
        type="button"
        data-pass-name="Carte 10 places après 15h"
        data-pass-price="89€"
        data-pass-rules="Valable après 15h en semaine uniquement, hors vendredi soir et hors week-end."
      >
        Acheter cette carte
      </button>
    </article>
  </div>

  <div class="passes-info">
    <div class="passes-info-box">
      <h4>Bon à savoir</h4>
      <p>
        Les cartes sont nominatives et les places sont déduites selon le nombre de participants
        sélectionnés lors de la réservation.
      </p>
    </div>

    <div class="passes-info-box passes-info-box--warning">
      <h4>Conditions d’utilisation</h4>
      <p>
        Les cartes ne sont pas cumulables avec un code promotionnel. Cette règle devra être
        bloquée côté backend lors de l’utilisation.
      </p>
    </div>
  </div>

  <!-- Modal simple -->
  <div class="passes-modal" id="passes-modal" aria-hidden="true">
    <div class="passes-modal-backdrop" data-close-pass-modal></div>

    <div
      class="passes-modal-content"
      role="dialog"
      aria-modal="true"
      aria-labelledby="passes-modal-title"
    >
      <button class="passes-modal-close" type="button" aria-label="Fermer" data-close-pass-modal>
        ×
      </button>

      <p class="passes-modal-kicker">Carte sélectionnée</p>
      <h3 id="passes-modal-title">Carte</h3>
      <p class="passes-modal-price" id="passes-modal-price"></p>
      <p class="passes-modal-rules" id="passes-modal-rules"></p>

      <div class="passes-modal-actions">
        <a href="/reservation.html" class="passes-modal-primary">
          Continuer
        </a>
        <button type="button" class="passes-modal-secondary" data-close-pass-modal>
          Fermer
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .singbox-passes {
    width: min(1200px, calc(100% - 32px));
    margin: 64px auto;
    color: #f9fafb;
  }

  .passes-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .passes-kicker {
    margin: 0 0 8px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #f97316;
  }

  .passes-header h2 {
    margin: 0 0 12px;
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.1;
  }

  .passes-subtitle {
    margin: 0 auto;
    max-width: 760px;
    color: rgba(249, 250, 251, 0.78);
    font-size: 16px;
    line-height: 1.6;
  }

  .passes-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    margin-top: 32px;
  }

  .pass-card {
    position: relative;
    padding: 28px;
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02)),
      #0b1020;
    border: 1px solid rgba(249, 250, 251, 0.1);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.28);
    overflow: hidden;
  }

  .pass-card--highlight {
    border-color: rgba(249, 115, 22, 0.4);
    box-shadow: 0 24px 60px rgba(249, 115, 22, 0.12);
  }

  .pass-badge {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(249, 115, 22, 0.15);
    border: 1px solid rgba(249, 115, 22, 0.35);
    color: #fdba74;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 18px;
  }

  .pass-badge--dark {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.12);
    color: #e5e7eb;
  }

  .pass-card h3 {
    margin: 0 0 18px;
    font-size: 24px;
    line-height: 1.2;
  }

  .pass-price {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 18px;
  }

  .pass-price-value {
    font-size: 44px;
    font-weight: 800;
    line-height: 1;
    color: #ffffff;
  }

  .pass-price-note {
    font-size: 14px;
    color: rgba(249, 250, 251, 0.68);
  }

  .pass-description {
    margin: 0 0 18px;
    font-size: 15px;
    line-height: 1.6;
    color: rgba(249, 250, 251, 0.82);
  }

  .pass-features {
    margin: 0 0 24px;
    padding-left: 18px;
    color: rgba(249, 250, 251, 0.9);
  }

  .pass-features li {
    margin-bottom: 10px;
    line-height: 1.5;
  }

  .pass-button {
    width: 100%;
    min-height: 52px;
    border: none;
    border-radius: 14px;
    cursor: pointer;
    font-size: 15px;
    font-weight: 700;
    transition: transform 0.18s ease, opacity 0.18s ease, box-shadow 0.18s ease;
    background: linear-gradient(135deg, #f97316, #ea580c);
    color: #ffffff;
    box-shadow: 0 12px 30px rgba(249, 115, 22, 0.22);
  }

  .pass-button:hover {
    transform: translateY(-1px);
    opacity: 0.96;
  }

  .pass-button--secondary {
    background: rgba(255,255,255,0.08);
    color: #f9fafb;
    border: 1px solid rgba(255,255,255,0.12);
    box-shadow: none;
  }

  .passes-info {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-top: 28px;
  }

  .passes-info-box {
    padding: 20px;
    border-radius: 18px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
  }

  .passes-info-box--warning {
    border-color: rgba(249, 115, 22, 0.25);
  }

  .passes-info-box h4 {
    margin: 0 0 8px;
    font-size: 16px;
  }

  .passes-info-box p {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: rgba(249, 250, 251, 0.8);
  }

  .passes-modal {
    position: fixed;
    inset: 0;
    display: none;
    z-index: 9999;
  }

  .passes-modal.is-open {
    display: block;
  }

  .passes-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(3, 7, 18, 0.72);
    backdrop-filter: blur(4px);
  }

  .passes-modal-content {
    position: relative;
    z-index: 1;
    width: min(520px, calc(100% - 24px));
    margin: 10vh auto 0;
    padding: 28px;
    border-radius: 24px;
    background: #0b1020;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 24px 60px rgba(0,0,0,0.35);
  }

  .passes-modal-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 38px;
    height: 38px;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    font-size: 24px;
    line-height: 1;
    background: rgba(255,255,255,0.08);
    color: #fff;
  }

  .passes-modal-kicker {
    margin: 0 0 8px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #f97316;
  }

  .passes-modal-content h3 {
    margin: 0 0 12px;
    font-size: 28px;
    line-height: 1.2;
  }

  .passes-modal-price {
    margin: 0 0 12px;
    font-size: 22px;
    font-weight: 700;
  }

  .passes-modal-rules {
    margin: 0 0 24px;
    color: rgba(249, 250, 251, 0.78);
    line-height: 1.6;
  }

  .passes-modal-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .passes-modal-primary,
  .passes-modal-secondary {
    min-height: 48px;
    padding: 0 18px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
  }

  .passes-modal-primary {
    background: linear-gradient(135deg, #f97316, #ea580c);
    color: #fff;
    border: none;
  }

  .passes-modal-secondary {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    color: #fff;
  }

  @media (max-width: 820px) {
    .passes-grid,
    .passes-info {
      grid-template-columns: 1fr;
    }

    .pass-card,
    .passes-modal-content {
      padding: 22px;
    }

    .pass-price-value {
      font-size: 38px;
    }
  }
</style>

<script>
  (function () {
    const modal = document.getElementById("passes-modal");
    const modalTitle = document.getElementById("passes-modal-title");
    const modalPrice = document.getElementById("passes-modal-price");
    const modalRules = document.getElementById("passes-modal-rules");

    if (!modal || !modalTitle || !modalPrice || !modalRules) return;

    const openButtons = document.querySelectorAll(".pass-button");
    const closeButtons = document.querySelectorAll("[data-close-pass-modal]");

    function openModal(name, price, rules) {
      modalTitle.textContent = name || "Carte";
      modalPrice.textContent = price || "";
      modalRules.textContent = rules || "";
      modal.classList.add("is-open");
      modal.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      modal.classList.remove("is-open");
      modal.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    }

    openButtons.forEach((button) => {
      button.addEventListener("click", () => {
        openModal(
          button.dataset.passName,
          button.dataset.passPrice,
          button.dataset.passRules
        );
      });
    });

    closeButtons.forEach((button) => {
      button.addEventListener("click", closeModal);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && modal.classList.contains("is-open")) {
        closeModal();
      }
    });
  })();
</script>
